# Kopieer dit bestand naar mcp/.env en vul je eigen waarden in.
# mcp/.env staat in .gitignore en wordt NOOIT gecommit.

# Creatomate — video rendering. Dashboard → Settings → API
CREATOMATE_API_KEY=

# OpenAI — Whisper-transcriptie in /ad-render
OPENAI_API_KEY=

# Pixabay — royalty-free achtergrondmuziek (gratis account)
PIXABAY_API_KEY=

# Apify — Meta Ad Library scraping voor /ad-research
APIFY_API_KEY=

# Google Drive — pad naar service-account JSON (zelf naast dit bestand plaatsen,
# staat in .gitignore). Deel de B-roll- en output-mappen met het service-account-e-mailadres.
GOOGLE_DRIVE_SA_FILE=mcp/google-drive-service-account.json

